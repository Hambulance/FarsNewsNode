<!DOCTYPE html>
<html lang="fa" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= siteTitle %></title>
    <script>
      (() => {
        const savedTheme = localStorage.getItem("fnn-theme");
        document.documentElement.dataset.theme = savedTheme || "light";
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Merriweather:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/public/styles.css" />
  </head>
  <body data-current-page="<%= pagination.currentPage %>" data-current-search="<%= search.query %>">
    <div class="page-shell">
      <header class="hero">
        <div class="hero__brand">
          <div class="hero__topbar">
            <span class="hero__eyebrow">پایش زندهٔ خبرهای ایران</span>
            <button class="theme-toggle" id="theme-toggle" type="button" aria-label="تغییر تم" aria-pressed="false">
              <span class="theme-toggle__icon" aria-hidden="true"></span>
              <span class="theme-toggle__label">تم تیره</span>
            </button>
          </div>
          <h1>فارس نیوز نود</h1>
          <p>
            هوش مصنوعی خبرهای تازه را بررسی و تحلیل می‌کند، مهم‌ترین تحولات را جمع‌بندی می‌کند
            و جدیدترین به‌روزرسانی‌ها را به‌صورت زنده در اختیار شما می‌گذارد.
          </p>
          <form class="hero-search" action="/" method="get">
            <label class="hero-search__field" for="news-search">
              <input
                id="news-search"
                type="search"
                name="q"
                value="<%= search.query %>"
                placeholder="جستجو در خبرهای ذخیره‌شده..."
              />
            </label>
            <button class="hero-search__submit" type="submit">جستجو</button>
            <% if (search.isActive) { %>
              <a class="hero-search__reset" href="/">حذف جستجو</a>
            <% } %>
          </form>
        </div>
        <div class="hero__status">
          <div class="status-card">
            <span>وضعیت اتصال</span>
            <strong id="connection-status">در حال اتصال...</strong>
          </div>
          <div class="status-card">
            <span>نمایش در هر صفحه</span>
            <strong>۱۲ خبر</strong>
          </div>
        </div>
      </header>

      <section class="ticker" aria-label="تیترهای برتر">
        <div class="ticker__label">تیترهای برتر</div>
        <div class="ticker__viewport">
          <div class="ticker__track" id="ticker-track">
            <% tickerItems.forEach((item) => { %>
              <span class="ticker__item"><%= item.translatedTitle %></span>
            <% }) %>
          </div>
        </div>
      </section>

      <main id="news-container">
        <%- include("partials/news-feed", { newsItems, pagination, search }) %>
      </main>
    </div>

    <%- include("partials/footer") %>

    <script src="/public/client.js" defer></script>
  </body>
</html>
