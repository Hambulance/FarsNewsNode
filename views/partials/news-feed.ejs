<section class="news-feed">
  <%- include("pagination", { pagination }) %>

  <div class="news-list">
    <% if (newsItems.length === 0) { %>
      <article class="empty-state">
        <h2>هنوز خبری ذخیره نشده است</h2>
        <p>به‌محض دریافت اولین خبرهای مرتبط با ایران، این بخش به‌صورت زنده پر می‌شود.</p>
      </article>
    <% } %>

    <% newsItems.forEach((item) => { %>
      <article class="news-card" data-news-id="<%= item.id %>">
        <div class="news-card__meta">
          <div class="news-card__meta-row">
            <span class="meta-pill meta-pill--source">منبع: <strong class="latin-news" lang="en" dir="ltr"><%= item.sourceName %></strong></span>
            <span class="meta-pill meta-pill--id">شناسه داخلی: <strong><%= item.id %></strong></span>
          </div>
          <div class="news-card__meta-row news-card__meta-row--secondary">
            <span class="meta-pill meta-pill--time">انتشار: <strong><%= item.publishedAtFormatted %></strong></span>
            <% if (item.isNew) { %>
              <span class="news-badge">خبر جدید</span>
            <% } %>
          </div>
        </div>

        <div class="news-card__body">
          <div class="news-card__headline">
            <button
              class="news-card__title-button"
              type="button"
              data-full-title="<%- item.translatedTitle %>"
              data-full-summary="<%- item.translatedSummary || '' %>"
              aria-label="نمایش جزئیات کامل خبر"
            >
              <span class="news-card__title-text"><%= item.translatedTitle %></span>
            </button>
          </div>

          <% if (item.translatedSummary) { %>
            <div class="news-card__summary-block">
              <h3>خلاصه خبر</h3>
              <p class="news-card__summary"><%= item.translatedSummary %></p>
            </div>
          <% } %>

          <div class="news-card__original">
            <h3>عنوان اصلی</h3>
            <p class="latin-news" lang="en" dir="ltr"><%= item.originalTitle %></p>
          </div>
        </div>

        <div class="news-card__links">
          <a href="<%= item.sourceUrl %>" target="_blank" rel="noreferrer">مشاهده در گوگل نیوز</a>
        </div>
      </article>
    <% }) %>
  </div>

  <%- include("pagination", { pagination }) %>

  <div class="title-modal" id="title-modal" hidden>
    <div class="title-modal__backdrop" data-title-modal-close></div>
    <div class="title-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="title-modal-heading">
      <button class="title-modal__close" type="button" data-title-modal-close aria-label="بستن">×</button>
      <p class="title-modal__eyebrow">عنوان کامل خبر</p>
      <h2 class="title-modal__heading" id="title-modal-heading"></h2>
      <div class="title-modal__summary" id="title-modal-summary-block" hidden>
        <h3 class="title-modal__summary-label">خلاصه خبر</h3>
        <p class="title-modal__summary-text" id="title-modal-summary"></p>
      </div>
    </div>
  </div>
</section>
